<VBox alignment="CENTER" spacing="15" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 30;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cybersafe.controller.InfoPanelController">

    <Label fx:id="lblTitle" style="-fx-text-fill: #0f172a; -fx-font-size: 24; -fx-font-weight: bold;"/>
    <Separator/>
    <Label fx:id="lblContent" wrapText="true" style="-fx-text-fill: #334155; -fx-font-size: 16;"/>

    <HBox fx:id="animationContainer" prefHeight="100" alignment="CENTER"/> <!-- Zone pour mini-animations -->

    <Button text="J'AI COMPRIS ! 👍" onAction="#closePanel"
            style="-fx-background-color: #39ff14; -fx-text-fill: black; -fx-font-weight: bold; -fx-cursor: hand;"/>
</VBox>