<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.cybersafe.controller.MainController" stylesheets="@../style/main.css">

    <BorderPane fx:id="mainContent" styleClass="root">
        <!-- BARRE LATÉRALE (SIDEBAR) -->
        <left>
            <VBox spacing="15" styleClass="glass-pane" prefWidth="260" style="-fx-padding: 20; -fx-margin: 10;">
                <Label text="CYBERSAFE KIDS" style="-fx-text-fill: #7df9ff; -fx-font-size: 22; -fx-font-weight: bold;"/>
                <Separator opacity="0.2"/>

                <Button text=" EXPLORER" onAction="#showExplorer" maxWidth="Infinity" styleClass="btn-cyber">
                    <graphic><FontIcon iconLiteral="fas-map-marked-alt"/></graphic>
                </Button>
                <Button text=" DEFENDER GAME" onAction="#startGame" maxWidth="Infinity" styleClass="btn-cyber">
                    <graphic><FontIcon iconLiteral="fas-shield-virus"/></graphic>
                </Button>
                <Button text=" QUIZ ARENA" onAction="#showQuiz" maxWidth="Infinity" styleClass="btn-cyber">
                    <graphic><FontIcon iconLiteral="fas-brain"/></graphic>
                </Button>

                <Region VBox.vgrow="ALWAYS"/>

                <!-- ZONE CYBERBOT (IA ANIMÉE) -->
                <VBox alignment="CENTER" spacing="10" style="-fx-padding: 10;">

                    <!-- FIX MAJEUR : StackPane pour injecter CyberBotAvatar -->
                    <StackPane fx:id="botContainer" prefWidth="100" prefHeight="100" />

                    <Label fx:id="lblBotChat" text="..." wrapText="true" styleClass="cyberbot-bubble" minHeight="60"/>

                    <HBox spacing="5" alignment="CENTER">
                        <TextField fx:id="txtChatInput" promptText="Pose une question..." onAction="#handleAIChat"
                                   style="-fx-background-color: #0f172a; -fx-text-fill: white; -fx-border-color: #7df9ff; -fx-prompt-text-fill: #58a6ff;"
                                   HBox.hgrow="ALWAYS"/>
                        <Button text="GO" onAction="#handleAIChat" styleClass="btn-cyber" prefWidth="45"/>
                    </HBox>
                </VBox>
            </VBox>
        </left>

        <!-- ZONE CENTRALE (CONTENU DYNAMIQUE) -->
        <center>
            <VBox spacing="20" style="-fx-padding: 30;">
                <HBox spacing="20">
                    <!-- CARTE XP -->
                    <VBox styleClass="glass-pane" HBox.hgrow="ALWAYS" prefHeight="120" alignment="CENTER">
                        <Label text="EXPÉRIENCE" style="-fx-text-fill: #8b949e; -fx-font-size: 14;"/>
                        <Label fx:id="lblXP" text="0" style="-fx-text-fill: white; -fx-font-size: 36; -fx-font-weight: bold;"/>
                    </VBox>
                    <!-- CARTE NIVEAU -->
                    <VBox styleClass="glass-pane" HBox.hgrow="ALWAYS" alignment="CENTER">
                        <Label text="NIVEAU" style="-fx-text-fill: #8b949e; -fx-font-size: 14;"/>
                        <Label fx:id="lblLevel" text="1" style="-fx-text-fill: #bc00ff; -fx-font-size: 36; -fx-font-weight: bold;"/>
                    </VBox>
                </HBox>

                <!-- BARRE DE PROGRESSION NÉON -->
                <ProgressBar fx:id="xpBar" progress="0.0" maxWidth="Infinity" prefHeight="15" style="-fx-accent: #bc00ff;"/>

                <!-- SCÈNE DE JEU / MODULES -->
                <StackPane fx:id="gameArea" VBox.vgrow="ALWAYS" styleClass="glass-pane" style="-fx-background-color: rgba(15, 23, 42, 0.5);">
                    <Label text="PRÊT POUR TA MISSION ?" style="-fx-text-fill: #7df9ff; -fx-font-size: 18;"/>
                </StackPane>
            </VBox>
        </center>
    </BorderPane>
</StackPane>