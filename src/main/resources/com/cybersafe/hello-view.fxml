<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cybersafe.controller.MainController" style="-fx-padding: 40;">

    <Label text="🛡️ BIENVENUE DANS NEON DEFENDER" style="-fx-text-fill: #7df9ff; -fx-font-size: 28; -fx-font-weight: bold;"/>
    <Label text="Ta mission : Apprendre à protéger le monde numérique." style="-fx-text-fill: white; -fx-font-size: 16;"/>

    <Button text="COMMENCER LA PREMIÈRE MISSION" onAction="#startGame" styleClass="btn-cyber" prefWidth="300" prefHeight="50"/>
</VBox>
